<?xml version="1.0" ?>
<robot name="my_robot">
  
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.3"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.7 0.4 0.4"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.4 0.4 0.4"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="6.0"/>
      <inertia ixx="0.16000000000000003" ixy="0.0" ixz="0.0" iyy="0.16000000000000003" iyz="0.0" izz="0.16000000000000003"/>
    </inertial>
  </link>

  <!-- <link name="fork_link">
    <visual>
      <geometry>
        <box size="0.3 0.3 0.05"/>
      </geometry>
      <material name="gray">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.3 0.3 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.007708333333333333" ixy="0.0" ixz="0.0" iyy="0.007708333333333333" iyz="0.0" izz="0.015"/>
    </inertial>
  </link> -->

  <!-- <joint name="fork_joint" type="fixed">
    <parent link="base_link"/>
    <child link="fork_link"/>
    <origin rpy="0 0 0" xyz="0.4 0 -0.17"/>
  </joint> -->

  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.05"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.05" radius="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0001666666666666667" ixy="0.0" ixz="0.0" iyy="0.0001666666666666667" iyz="0.0" izz="0.00025000000000000006"/>
    </inertial>
  </link>

  <joint name="lidar_link_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.22"/>
  </joint>

  <link name="front_left_wheel">
    <visual>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001354166666666667" ixy="0.0" ixz="0.0" iyy="0.001354166666666667" iyz="0.0" izz="0.0025000000000000005"/>
    </inertial>
  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin rpy="0 0 0" xyz="0.2 0.235 -0.2"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <gazebo reference="front_left_wheel">
    <!-- Passive support wheel/caster: near-zero contact friction so it cannot scrub sideways. -->
    <mu1>0.05</mu1>
    <mu2>0.05</mu2>
    <kp>100000.0</kp>
    <kd>50.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
  </gazebo>

  <link name="front_right_wheel">
    <visual>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001354166666666667" ixy="0.0" ixz="0.0" iyy="0.001354166666666667" iyz="0.0" izz="0.0025000000000000005"/>
    </inertial>
  </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin rpy="0 0 0" xyz="0.2 -0.235 -0.2"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <gazebo reference="front_right_wheel">
    <mu1>0.05</mu1>
    <mu2>0.05</mu2>
    <kp>100000.0</kp>
    <kd>50.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
  </gazebo>

  <link name="rear_left_wheel">
    <visual>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001354166666666667" ixy="0.0" ixz="0.0" iyy="0.001354166666666667" iyz="0.0" izz="0.0025000000000000005"/>
    </inertial>
  </link>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin rpy="0 0 0" xyz="-0.2 0.235 -0.2"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.01"/>
  </joint>

  <gazebo reference="rear_left_wheel">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
    <kp>100000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
  </gazebo>

  <link name="rear_right_wheel">
    <visual>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001354166666666667" ixy="0.0" ixz="0.0" iyy="0.001354166666666667" iyz="0.0" izz="0.0025000000000000005"/>
    </inertial>
  </link>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin rpy="0 0 0" xyz="-0.2 -0.235 -0.2"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <gazebo reference="rear_right_wheel">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
    <kp>100000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
  </gazebo>

   <!-- ========================= -->
  <!-- SIMPLE FORKLIFT STRUCTURE -->
  <!-- Separate experimental forklift version -->
  <!-- ========================= -->

 <link name="forklift_mast_link">

    <!-- Left vertical rail -->
    <visual name="left_rail_visual">
      <origin xyz="0 0.17 0.30" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.05 0.80"/>
      </geometry>
      <material name="mast_dark_gray">
        <color rgba="0.05 0.05 0.05 1"/>
      </material>
    </visual>

    <collision name="left_rail_collision">
      <origin xyz="0 0.17 0.30" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.05 0.80"/>
      </geometry>
    </collision>

    <!-- Right vertical rail -->
    <visual name="right_rail_visual">
      <origin xyz="0 -0.17 0.30" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.05 0.80"/>
      </geometry>
      <material name="mast_dark_gray">
        <color rgba="0.05 0.05 0.05 1"/>
      </material>
    </visual>

    <collision name="right_rail_collision">
      <origin xyz="0 -0.17 0.30" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.05 0.80"/>
      </geometry>
    </collision>

    <!-- Top crossbar -->
    <visual name="top_crossbar_visual">
      <origin xyz="0 0 0.70" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.40 0.05"/>
      </geometry>
      <material name="mast_dark_gray">
        <color rgba="0.05 0.05 0.05 1"/>
      </material>
    </visual>

    <collision name="top_crossbar_collision">
      <origin xyz="0 0 0.70" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.40 0.05"/>
      </geometry>
    </collision>

    <!-- Bottom crossbar, low enough to stay below lidar view -->
    <visual name="bottom_crossbar_visual">
      <origin xyz="0 0 -0.08" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.40 0.05"/>
      </geometry>
      <material name="mast_dark_gray">
        <color rgba="0.05 0.05 0.05 1"/>
      </material>
    </visual>

    <collision name="bottom_crossbar_collision">
      <origin xyz="0 0 -0.08" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.40 0.05"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.30" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.035" ixy="0.0" ixz="0.0" iyy="0.004" iyz="0.0" izz="0.035"/>
    </inertial>
  </link>

  <joint name="forklift_mast_joint" type="fixed">
    <parent link="base_link"/>
    <child link="forklift_mast_link"/>
    <origin xyz="0.38 0 -0.10" rpy="0 0 0"/>
  </joint>

  <link name="fork_carriage_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.35 0.18"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.35 0.18"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.4"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="fork_carriage_joint" type="fixed">
    <parent link="forklift_mast_link"/>
    <child link="fork_carriage_link"/>
    <origin xyz="0.05 0 -0.0" rpy="0 0 0"/>
  </joint>

  <link name="left_fork_link">
    <visual>
      <origin xyz="0.32 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.60 0.055 0.04"/>
      </geometry>
      <material name="fork_yellow">
        <color rgba="1.0 0.75 0.0 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0.32 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.70 0.055 0.04"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0.32 0 0" rpy="0 0 0"/>
      <mass value="0.25"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.010" iyz="0.0" izz="0.010"/>
    </inertial>
  </link>

  <joint name="left_fork_joint" type="fixed">
    <parent link="fork_carriage_link"/>
    <child link="left_fork_link"/>
    <origin xyz="0.01 0.11 -0.065" rpy="0 0 0"/>
  </joint>

  <link name="right_fork_link">
    <visual>
      <origin xyz="0.32 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.60 0.055 0.04"/>
      </geometry>
      <material name="fork_yellow">
        <color rgba="1.0 0.75 0.0 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0.32 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.70 0.055 0.04"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0.32 0 0" rpy="0 0 0"/>
      <mass value="0.25"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.010" iyz="0.0" izz="0.010"/>
    </inertial>
  </link>

  <joint name="right_fork_joint" type="fixed">
    <parent link="fork_carriage_link"/>
    <child link="right_fork_link"/>
    <origin xyz="0.01 -0.11 -0.065" rpy="0 0 0"/>
  </joint>


  <link name="imu_link"/>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <ros>
          <remapping>~/out:=imu/data</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin filename="libgazebo_ros_diff_drive.so" name="rear_diff_drive">
      <update_rate>100</update_rate>
      <num_wheel_pairs>1</num_wheel_pairs>

      <!-- True differential-drive setup: only the rear wheels are actuated. -->
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>rear_right_wheel_joint</right_joint>

      <wheel_separation>0.47</wheel_separation>
      <wheel_diameter>0.2</wheel_diameter>
      <max_wheel_torque>80</max_wheel_torque>
      <max_wheel_acceleration>6</max_wheel_acceleration>

      <covariance_x>0.0001</covariance_x>
      <covariance_y>0.0001</covariance_y>
      <covariance_yaw>0.01</covariance_yaw>

      <publish_odom>true</publish_odom>
      <publish_odom_tf>false</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>

      <odometry_source>0</odometry_source>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>

  <gazebo reference="lidar_link">
    <sensor name="lidar_3d" type="ray">
      <always_on>true</always_on>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.0</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1.0</resolution>
            <min_angle>-0.261799</min_angle>
            <max_angle>0.261799</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.40</min>
          <max>12.0</max>
          <resolution>0.015</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin filename="libgazebo_ros_ray_sensor.so" name="scan_3d">
        <ros>
          <remapping>~/out:=points</remapping>
        </ros>
        <output_type>sensor_msgs/PointCloud2</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin filename="libgazebo_ros_joint_state_publisher.so" name="wheel_encoder_plugin">
      <update_rate>100.0</update_rate>
      <joint_name>front_left_wheel_joint</joint_name>
      <joint_name>front_right_wheel_joint</joint_name>
      <joint_name>rear_left_wheel_joint</joint_name>
      <joint_name>rear_right_wheel_joint</joint_name>
    </plugin>
  </gazebo>

  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>

    <!-- ========================= -->
  <!-- Gazebo colors for forklift -->
  <!-- ========================= -->

  <gazebo reference="forklift_mast_link">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="fork_carriage_link">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="left_fork_link">
    <material>Gazebo/Orange</material>
  </gazebo>

  <gazebo reference="right_fork_link">
    <material>Gazebo/Orange</material>
  </gazebo>

   <gazebo reference="front_left_wheel_link">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="front_right_wheel_link">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="rear_left_wheel_link">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="rear_right_wheel_link">
    <material>Gazebo/Black</material>
  </gazebo>

</robot>